APP_NAME="Bolão Copa 2026"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000
APP_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bolao
DB_USERNAME=bolao
DB_PASSWORD=bolao

BROADCAST_CONNECTION=pusher
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Soketi (Pusher protocol compatible)
PUSHER_APP_ID=bolao
PUSHER_APP_KEY=bolaokey
PUSHER_APP_SECRET=bolaosecret
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"

SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# Bolão
BOLAO_MODE=full  # 'groups' or 'full'
POINTS_EXACT=5
POINTS_WINNER=2
PREDICTION_LOCK_MINUTES=60
